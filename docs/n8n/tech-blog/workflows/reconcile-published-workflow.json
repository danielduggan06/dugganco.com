                  {
                      "parameters":  {
                                         "mode":  "runOnceForEachItem",
                                         "language":  "javaScript",
                                         "jsCode":  "const source = $(\u0027Build Reconcile Plan\u0027).first().json;\nconst canonical = new Set(source.canonical_slugs || []);\n\nlet manifestEntries = [];\nif ($binary?.manifest?.data) {\n  try {\n    manifestEntries = JSON.parse(Buffer.from($binary.manifest.data, \u0027base64\u0027).toString(\u0027utf8\u0027));\n  } catch (error) {\n    manifestEntries = [];\n  }\n}\n\nif (!Array.isArray(manifestEntries)) manifestEntries = [];\n\nconst filtered = manifestEntries\n  .filter((entry) =\u003e canonical.has(String(entry.slug || \u0027\u0027).trim()))\n  .sort((a, b) =\u003e new Date(b.published_at).getTime() - new Date(a.published_at).getTime());\n\nconst payload = {\n  keep_slugs: Array.from(canonical).sort(),\n  manifest_entries: filtered\n};\n\nreturn [{\n  json: {\n    manifest_path: source.manifest_path,\n    manifest_json: JSON.stringify(filtered, null, 2),\n    repo_payload_b64: Buffer.from(JSON.stringify(payload), \u0027utf8\u0027).toString(\u0027base64\u0027)\n  }\n}];"
                                     },
