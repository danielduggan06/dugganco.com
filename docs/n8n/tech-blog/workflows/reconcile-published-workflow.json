                                                           }
                                      }
                  },
                  {
                      "parameters":  {
                                         "mode":  "runOnceForAllItems",
                                         "language":  "javaScript",
                                         "jsCode":  "const source = $(\u0027Build Canonical Slugs\u0027).first().json;\nconst canonical = new Set(source.canonical_slugs || []);\nconst items = $input.all();\n\nconst orphanJsonPaths = [];\n\nfor (const item of items) {\n  if (item.json.type !== \u0027file\u0027) continue;\n  const path = decodeURIComponent(String(item.json.path || \u0027\u0027));\n  if (!path.toLowerCase().endsWith(\u0027.json\u0027)) continue;\n  const fileName = path.split(\u0027/\u0027).pop() || \u0027\u0027;\n  const slug = fileName.replace(/\\.json$/i, \u0027\u0027);\n  const normalizedPath = path.startsWith(\u0027/\u0027) ? path : `/${path}`;\n  if (!canonical.has(slug)) {\n    orphanJsonPaths.push(normalizedPath);\n  }\n}\n\nreturn [{\n  json: {\n    canonical_slugs: source.canonical_slugs || [],\n    manifest_path: source.manifest_path,\n    orphan_json_paths: orphanJsonPaths.sort()\n  }\n}];"
                                     },
