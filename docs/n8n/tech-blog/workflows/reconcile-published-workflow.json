                  {
                      "parameters":  {
                                         "mode":  "runOnceForAllItems",
                                         "language":  "javaScript",
                                         "jsCode":  "const items = $input.all();\nconst canonical = new Set();\n\nfor (const item of items) {\n  if (item.json.type !== \u0027file\u0027) continue;\n  const path = decodeURIComponent(String(item.json.path || \u0027\u0027));\n  const fileName = path.split(\u0027/\u0027).pop() || \u0027\u0027;\n  const match = fileName.match(/^\\d{4}-\\d{2}-\\d{2}-(.+)\\.md$/i);\n  if (match) canonical.add(match[1]);\n}\n\nreturn [{\n  json: {\n    canonical_slugs: Array.from(canonical).sort(),\n    manifest_path: \u0027/Notes/Blog Articles/4-Published/json/blog-manifest.json\u0027\n  }\n}];"
                                     },
